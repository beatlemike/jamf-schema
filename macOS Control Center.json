{
  "title": "Control Center (com.apple.controlcenter)",
  "description": "Manages Control Center menu bar icon visibility",
  "__version": "1.0",
  "__feedback": "your.email@cpp.edu",
  "options": {
    "remove_empty_properties": true
  },
  "properties": {
    "WiFi": {
      "title": "Wi-Fi Menu Bar Icon",
      "description": "Controls Wi-Fi icon visibility in the menu bar",
      "property_order": 10,
      "anyOf": [
        {
          "type": "null",
          "title": "Not Configured"
        },
        {
          "type": "integer",
          "title": "Configured",
          "enum": [2, 8, 18],
          "options": {
            "enum_titles": [
              "Show in Menu Bar (2)",
              "Don't Show in Menu Bar (8)",
